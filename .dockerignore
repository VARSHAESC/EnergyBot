# Python runtime artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Virtual environments
venv/
.venv/

# Node / frontend build artifacts (frontend has its own Dockerfile)
frontend/node_modules/
frontend/dist/

# Data volumes — populated at runtime via named volumes in compose.yaml
cache/
chroma_db/

# Logs
*.log
app.log

# Dev / scratch files
scratch/
temp_client_data/
*.bat
*.ps1

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/

# Secrets — injected via env_file in compose.yaml, never baked into image
.env
.env.template
