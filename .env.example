# --- Azure Configuration ---
# Set these to enable Azure OpenAI integration
AZURE_OPENAI_ENDPOINT=https://energyapi.openai.azure.com/openai/deployments/gpt-5-chat/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_KEY=your_azure_openai_key_here
LLM_MODEL_NAME=gpt-5-chat

# --- App Credentials ---
# These should be stored in Azure Key Vault and mapped to environment variables
APP_USERNAME=admin
APP_PASSWORD=esc_service_2026

# --- Data Configuration ---
# Path to the Excel file (relative to root)
DATA_FILE=excel_data/Hausanschluss_data.xlsx

# --- Vector Store ---
EMBED_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
OFFLINE_MODE=false
