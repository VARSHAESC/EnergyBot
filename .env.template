# ─────────────────────────────────────────────────────────────────────────────
# EnergyBot — Environment Configuration
# Copy this file to .env and fill in your values before running Docker.
# NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / LLM Connection ──────────────────────────────────────────────────────
# Groq (free tier works well): https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL_NAME=llama-3.3-70b-versatile

# ── Embedding model (downloaded once during image build) ─────────────────────
EMBED_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
